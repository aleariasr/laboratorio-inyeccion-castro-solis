[Unit]
Description=LICS Chromium kiosk
After=graphical-session.target
Wants=graphical-session.target

[Service]
Type=simple
WorkingDirectory=/opt/lics
ExecStartPre=/opt/lics/scripts/wait-for-lics.sh
ExecStart=/opt/lics/scripts/start-kiosk.sh
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
